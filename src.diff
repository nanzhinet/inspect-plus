+                        e.stopPropagation();
+                        toggleLeafByLabelClick(String(option.key));
+                      },
+                    },
+                    option.label as string,
+                  )
+          "
+          :node-props="candidateTreeNodeProps"
+          :data="candidateTreeOptions"
+          :checked-keys="selectedCandidateKeys"
+          @update:checkedKeys="onCandidateTreeChecked"
+        />
+      </NCard>
+      <div
