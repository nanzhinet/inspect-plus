+      console.log('[DialogService] 跳过分享警告：用户已设置忽略');
+      return;
+    }
+    console.log('[DialogService] 显示分享警告弹窗');
+    try {
+      await this.openRiskNotice();
+      console.log('[DialogService] 用户确认分享');
+    } catch (error) {
+      console.log('[DialogService] 用户取消分享:', error);
