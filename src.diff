+  align-items: center;
+  padding: 12px 16px;
+  cursor: move;
+}
+
+.n-modal-title {
+  font-size: 16px;
+  font-weight: 500;
+}
+
+.n-modal-header__right {
+  flex-shrink: 0;
+}
+
+/* 确保弹窗可见 */
+.snapshot-floating-panel {
+  z-index: 10000;
+}
+</style>
